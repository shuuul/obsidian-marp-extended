{
  "compilerOptions": {
    "baseUrl": "./src",
    "rootDir": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["*"],
      "@test/*": ["../tests/*"]
    },
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES6",
    "allowJs": true,
    "noImplicitAny": true,
    "strictPropertyInitialization": false,
    "moduleResolution": "node",
    "isolatedModules": true,
	  "strictNullChecks": true,
    "esModuleInterop": true,
    "types": [
      "node",
      "jest"
    ],
    "lib": [
      "DOM",
      "ES5",
      "ES6",
      "ES7"
    ]
  },
  "include": [
    "**/*.ts"
  ]
}
