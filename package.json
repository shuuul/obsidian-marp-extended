{
	"name": "marp-extended",
	"version": "0.4.1",
	"description": "Create markdown-based Marp presentations in Obsidian with extended Marp support",
	"main": "main.js",
	"scripts": {
		"postinstall": "node scripts/postinstall.mjs",
		"dev": "node esbuild.config.mjs",
		"build": "npm run typecheck && node esbuild.config.mjs production",
		"test": "node scripts/run-jest.js",
		"test:watch": "node scripts/run-jest.js --watch",
		"test:coverage": "node scripts/run-jest.js --coverage",
		"obsidian:reload": "node scripts/reload-obsidian-plugin.mjs",
		"obsidian:profile": "node scripts/profile-obsidian-plugin.mjs",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"typecheck": "tsc --noEmit --skipLibCheck",
		"lint": "eslint \"{src,tests}/**/*.ts\"",
		"lint:fix": "npm run lint -- --fix",
		"analyze:bundle": "npm run typecheck && node esbuild.config.mjs production --analyze"
	},
	"keywords": [],
	"author": "shuuul",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/jest": "^30.0.0",
		"@types/node": "^26.0.1",
		"@typescript-eslint/eslint-plugin": "^8.62.0",
		"@typescript-eslint/parser": "^8.62.0",
		"esbuild": "^0.28.1",
		"eslint": "^10.5.0",
		"globals": "^17.7.0",
		"jest": "^30.4.2",
		"markdown-it-container": "^4.0.0",
		"markdown-it-mark": "^4.0.0",
		"obsidian": "^1.13.1",
		"ts-jest": "^29.4.11",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@marp-team/marp-cli": "^4.4.0",
		"@marp-team/marp-core": "^4.3.0",
		"beautiful-mermaid": "^1.1.3",
		"jszip": "^3.10.1"
	}
}
